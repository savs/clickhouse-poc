# Environment Variables for Grafana Stack

# ClickHouse Configuration
CLICKHOUSE_USER=grafana
CLICKHOUSE_PASSWORD=grafana
CLICKHOUSE_DB=default

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# PDC Configuration
GCLOUD_PDC_SIGNING_TOKEN=your-pdc-signing-token-here
GCLOUD_PDC_CLUSTER=your-pdc-cluster-here
GCLOUD_HOSTED_GRAFANA_ID=your-hosted-grafana-id-here

# Frontend / Grafana / Alloy authentication
# Username and password for HTTP basic auth on all public HTTPS endpoints.
FRONTEND_USER=admin
FRONTEND_PASSWORD=changeme

# Let's Encrypt contact email (required for certificate issuance)
CERT_EMAIL=your-email@example.com

# Network Configuration
GRAFANA_PORT=3000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
ALLOY_PORT=12345
PDC_PORT=8080
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
